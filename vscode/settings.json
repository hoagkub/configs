{
    "security.workspace.trust.untrustedFiles": "open",
    "editor.multiCursorPaste": "full",
    "vscode-office.openOutline": true,
    "git.mergeEditor": true,
    "files.exclude": {
        "**/.DS_Store": false,
        "**/.git": false,
        "**/.hg": false,
        "**/.svn": false,
        "**/CVS": false,
        "**/Thumbs.db": false
    },
    "notebook.output.scrolling": true,
    "workbench.editor.showTabs": "single",
    "workbench.tree.indent": 16,
    "editor.renderWhitespace": "all",
    "notebook.editorOptionsCustomizations": {
        "editor.tabSize": 4,
        "editor.indentSize": 4,
        "editor.insertSpaces": true
    },
    "remote.SSH.defaultExtensions": [
        "cweijan.vscode-office",
        "eamodio.gitlens",
        "github.github-vscode-theme",
        "gitlab.gitlab-workflow",
        "ms-python.debugpy",
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-keymap",
        "ms-toolsai.jupyter-renderers",
        "ms-toolsai.vscode-jupyter-cell-tags",
        "ms-toolsai.vscode-jupyter-slideshow",
        "ms-vscode-remote.remote-containers",
        "ms-vscode-remote.remote-ssh",
        "ms-vscode-remote.remote-ssh-edit",
        "ms-vscode-remote.remote-wsl",
        "ms-vscode-remote.vscode-remote-extensionpack",
        "ms-vscode.remote-explorer",
        "ms-vscode.remote-server",
        "ryu1kn.partial-diff",
        "t-nano.markdown-to-confluence-vscode",
        "yo1dog.cursor-align",
        "sleistner.vscode-fileutils",
        "yzhang.markdown-all-in-one",
        "LeonKohli.snapsource",
        "Anthropic.claude-code"
    ],
    "workbench.editorAssociations": {
        "*.copilotmd": "vscode.markdown.preview.editor",
        "*.md": "default",
        "*.csv": "default",
        "*.markdown": "default",
        "*.txt": "default"
    },
    "notebook.diff.ignoreMetadata": true,
    "notebook.diff.ignoreOutputs": true,
    "diffEditor.renderSideBySide": true,
    "remote.autoForwardPortsSource": "hybrid",
    "explorer.autoReveal": false,
    "terminal.integrated.profiles.linux": {
        "bash-tmux": {
            "path": "bash",
            "args": [
                "-c",
                "unset VSCODE_IPC_HOOK_CLI VSCODE_CWD; export XDG_RUNTIME_DIR=/run/user/$(id -u); SESSION=vscode_dercules; (tmux new-window -t $SESSION; tmux new-session -A -D -s $SESSION) || bash"
            ],
        }
    },
    "terminal.integrated.commandsToSkipShell": [
        "-workbench.action.terminal.paste"
    ],
    "terminal.integrated.defaultProfile.linux": "bash-tmux",
    "vscode-office.editorTheme": "Github Dark",
    "gitlens.views.commits.files.layout": "tree",
    "editor.fontSize": 16,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "notebook.insertFinalNewline": true,
    "workbench.list.horizontalScrolling": true,
    "workbench.sideBar.location": "right",
    "gitlens.views.scm.grouped.views": {
        "commits": true,
        "branches": true,
        "remotes": true,
        "stashes": false,
        "tags": true,
        "worktrees": true,
        "contributors": true,
        "fileHistory": false,
        "repositories": true,
        "searchAndCompare": true,
        "launchpad": false
    },
    "workbench.colorTheme": "GitHub Dark",
    "explorer.compactFolders": false,
    "scm.compactFolders": false,
    "terminal.integrated.fontSize": 15,
    "workbench.editor.enablePreview": false,
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1",
    "terminal.integrated.defaultLocation": "editor",
    "remote.SSH.lockfilesInTmp": true,
    "remote.SSH.useLocalServer": false,
    "remote.SSH.remotePlatform": {
        "release-test-sub-server": "linux"
    },
    "python.terminal.activateEnvironment": false,
    "git.autoRepositoryDetection": false
}
